# Copy file ini ke .env dan sesuaikan dengan konfigurasi lokal
# JANGAN commit .env ke repository, hanya commit .env.example

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_NAME=lapangan_booking
DB_PORT=3306

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_at_least_32_characters_long
JWT_EXPIRE=7d

# Payment Expiry (dalam menit)
PAYMENT_EXPIRY_MINUTES=15
